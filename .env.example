# Application
APP_ENV=dev
PORT=8000
LOG_LEVEL=INFO
HOST=0.0.0.0

# Redis
REDIS_URL=redis://localhost:6379/0

# Postgres (optional)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/wizard

# Security
TENANT_KEYS_JSON={"boom":"API_KEY_123_CHANGE_ME"}
HMAC_SECRET=change_me_in_production

# LLM Provider (openai|gemini|claude)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-pro

# Claude
ANTHROPIC_API_KEY=...
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Session
SESSION_TTL_SECONDS=3600
MAX_CONVERSATION_BUFFER=10
