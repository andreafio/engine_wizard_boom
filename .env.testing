# Copy this to .env and configure your settings
# cp .env.testing .env

# Application
APP_ENV=dev
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://localhost:6379/0

# Postgres (optional)
# DATABASE_URL=postgresql+asyncpg://wizard:wizard_pass@localhost:5432/wizard

# Security (CHANGE IN PRODUCTION!)
TENANT_KEYS_JSON={"boom":"API_KEY_123_CHANGE_ME","test":"TEST_KEY_456"}
HMAC_SECRET=change_me_in_production_use_long_random_string

# LLM Provider (choose: openai, gemini, or claude)
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Configuration (if using gemini)
# GEMINI_API_KEY=your-gemini-key-here
# GEMINI_MODEL=gemini-pro

# Anthropic Claude Configuration (if using claude)
# ANTHROPIC_API_KEY=your-claude-key-here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Session Configuration
SESSION_TTL_SECONDS=3600
MAX_CONVERSATION_BUFFER=10
